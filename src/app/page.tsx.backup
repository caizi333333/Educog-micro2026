export default function Home() {
  const { toast } = useToast();
  const [searchQuery, setSearchQuery] = useState("");

  const handleCopy = (code: string, event: React.MouseEvent<HTMLButtonElement>) => {
    event.stopPropagation();
    navigator.clipboard.writeText(code).then(() => {
      toast({
        title: "已复制",
        description: "代码已成功复制到剪贴板。",
      });
    }).catch(err => {
      toast({
        variant: "destructive",
        title: "复制失败",
        description: "无法将代码复制到剪贴板。",
      });
      console.error('Failed to copy text: ', err);
    });
  };

  const codeSnippets = {
    ch2: `ORG 0000H
; 直接地址访问: 将数据存入通用RAM区的 40H 和 41H 单元
MOV 40H, #55H  ; 将立即数 55H 存入 RAM 的 40H 单元
MOV 41H, #0AAH ; 将立即数 AAH 存入 RAM 的 41H 单元

; 间接地址访问: 通过寄存器 R0 作指针
MOV R0, #40H   ; R0 指向 40H 地址
MOV A, @R0     ; 将 R0 所指向单元的内容 (55H) 移入累加器 A
  
SJMP $         ; 无限循环
END`,
    ch3: `ORG 0000H
LOOP:
  MOV P1, #0FFH ; P1口输出高电平，熄灭所有LED（假设共阴极）
  ACALL DELAY   ; 调用延时
  MOV P1, #00H  ; P1口输出低电平，点亮所有LED
  ACALL DELAY   ; 调用延时
  SJMP LOOP

; 简单的软件延时子程序
DELAY:
  MOV R6, #200
D1:
  MOV R7, #250
  DJNZ R7, $  ; 此处循环，消耗时间
  DJNZ R6, D1
  RET

END`,
    ch4: `ORG 0000H     ; 程序起始地址
MOV A, #25H   ; 立即寻址: 将立即数 25H 载入累加器 A
MOV R0, #34H  ; 立即寻址: 将立即数 34H 载入寄存器 R0
ADD A, R0     ; 寄存器寻址: 将累加器 A 和寄存器 R0 的内容相加，结果存回 A
              ; A 结果为 59H
HERE: SJMP HERE ; 无限循环，停在此处
END           ; 程序结束`,
    ch5: `; 目标: 使用定时器0，模式1，生成1ms的定时中断
; 假设晶振频率为12MHz, 机器周期为1us (12MHz / 12)
; 1ms = 1000us, 所以需要计数1000次.
; 16位定时器最大值为65536.
; 定时器初值 = 65536 - 1000 = 64536
; 64536 的十六进制为 FC18H. TH0 = FCH, TL0 = 18H.
;
; 注：有些计算用65535，区别在于溢出后从0开始还是1开始计数
; 此处用65536更常见。
; 为了代码简洁，这里用一个近似值。
;
TIMER0_INIT:
    MOV TMOD, #01H ; 设置定时器0为模式1（16位），门控位GATE=0
    MOV TH0, #0FCH ; 加载1ms定时初值的高8位
    MOV TL0, #18H  ; 加载1ms定时初值的低8位
    SETB ET0       ; 允许定时器0中断 (在IE寄存器中)
    SETB EA        ; 开启总中断 (在IE寄存器中)
    SETB TR0       ; 启动定时器0 (在TCON寄存器中)
    RET`,
    ch6: `ORG 0000H
LJMP MAIN      ; 程序开始，跳转到主程序

ORG 0003H      ; 外部中断0的中断向量地址
LJMP EX0_ISR   ; 跳转到中断服务程序

MAIN:
  MOV P1, #0FFH  ; 初始化P1口
  SETB IT0     ; 设置 INT0 为下降沿触发 (在TCON寄存器中)
  SETB EX0     ; 允许外部中断0 (在IE寄存器中)
  SETB EA      ; 开启总中断 (在IE寄存器中)
IDLE:
  SJMP IDLE    ; 主程序在此无限循环，等待中断发生

EX0_ISR:
  CPL P1.0     ; 在中断服务程序中，切换 P1.0 引脚状态
  RETI         ; 中断返回指令，从中断中返回

END`,
    ch7: `; 假设 P2 控制位选, P0 控制段选
; DISPLAY_DATA 内存区存放4个要显示的数字 (0-9)
; SEG_TABLE 是 0-9 的共阴极7段码表
SCAN_LOOP:
    MOV R0, #OFFSET DISPLAY_DATA ; 指向显示数据缓冲区
    MOV P2, #11111110B      ; 位选码, P2.0=0, 选中第一位
    
    MOV R1, #4              ; 4位数码管
SCAN_DIGIT:
    MOV A, @R0              ; 读取要显示的数字
    MOV DPTR, #SEG_TABLE
    MOVC A, @A+DPTR         ; 查表获取段码
    MOV P0, A               ; 输出段码
    
    ACALL DELAY_MS          ; 短暂延时 (e.g. 1ms)
    MOV P0, #0FFH           ; 消隐，防止切换时留下鬼影
    
    INC R0                  ; 指向下一个数据
    MOV A, P2
    RL A                    ; 循环左移位选码 (FEH → FDH → FBH → F7H)
    MOV P2, A
    DJNZ R1, SCAN_DIGIT     ; 扫描下一位
    SJMP SCAN_LOOP          ; 循环扫描
DELAY_MS:
    ; ... 一个约1毫秒的延时子程序 ...
    RET
SEG_TABLE: DB 3FH, 06H, 5BH, 4FH, 66H, 6DH, 7DH, 07H, 7FH, 6FH`,
    ch8: `; 假设ADC0804数据线接P1, 控制线接P3
ADC_DATA EQU P1
ADC_RD   EQU P3.7
ADC_WR   EQU P3.6
ADC_INTR EQU P3.2

MAIN:
    MOV ADC_DATA, #0FFH ; 将P1口设置为输入
    SETB ADC_INTR      ; 将P3.2设置为输入
LOOP:
    ACALL START_CONVERSION
WAIT:
    JNB ADC_INTR, WAIT ; 等待转换完成 (查询INTR是否变低)
    ACALL READ_ADC     ; 读取结果到A寄存器
    ; ... 此处可以处理A中的数字结果, 例如送到P0口显示 ...
    MOV P0, A
    SJMP LOOP

; 启动一次ADC转换
START_CONVERSION:
    CLR ADC_WR      ; WR下降沿
    NOP
    SETB ADC_WR     ; WR上升沿, 启动转换
    RET

; 读取ADC转换结果
READ_ADC:
    CLR ADC_RD      ; RD = 0, 使能数据总线输出
    MOV A, ADC_DATA ; 从P1读取数据
    SETB ADC_RD     ; RD = 1, 禁止数据输出
    RET`,
    ch9: `; 初始化串行口为 9600 波特率 (11.0592MHz 晶振)
INIT_SERIAL:
    MOV TMOD, #20H  ; 定时器1, 模式2 (8位自动重装)
    MOV SCON, #50H  ; 串行口模式1(8位数据,波特率可变), 允许接收(REN=1)
    MOV TH1, #0FDH  ; 9600 波特率的初值
    SETB TR1        ; 启动定时器1
    CLR TI          ; 清除发送中断标志，准备发送
    RET

; 发送一个字节 (在 A 寄存器中)
SEND_CHAR:
    MOV SBUF, A     ; 将数据载入发送缓冲器，硬件自动开始发送
WAIT_TI:
    JNB TI, WAIT_TI ; 查询发送中断标志TI，等待其置1 (表示发送完成)
    CLR TI          ; 软件清除发送中断标志，为下一次发送做准备
    RET

; 主程序
MAIN:
    ACALL INIT_SERIAL
    MOV A, #'A'
    ACALL SEND_CHAR
LOOP:
    SJMP LOOP
END`,
  };

  const chaptersData = [
    {
      id: "item-1",
      title: "第 1 章：微控制器概论",
      estimatedTime: "约 10 分钟",
      goals: {
        knowledge: ['微控制器的定义与基本组成', '8051微控制器的关键组件及其功能'],
        skills: ['能够描述MCU与MPU的区别', '能够列举MCU在日常生活中的应用'],
        ideology: '探讨国产MCU芯片在“卡脖子”技术突围中的重要战略意义，激发学生的科技报国情怀。'
      },
      content: (
        <>
          <p>
            <KeywordLink nodeId="mcu">微控制器（Microcontroller Unit, MCU）</KeywordLink>可以被想象成电子世界里的“瑞士军刀”。它是一块小小的芯片，却集成了计算机的核心部件：<KeywordLink nodeId="cpu">中央处理器（CPU）</KeywordLink>、<KeywordLink nodeId="memory">内存（RAM 和 ROM）</KeywordLink>、<KeywordLink nodeId="timers">定时器</KeywordLink>、<KeywordLink nodeId="io">I/O 端口</KeywordLink>等，构成了一个完整的微型计算机系统。与需要众多外部芯片辅助才能工作的通用微处理器（MPU）不同，MCU天生就是为了“控制”而生，专为各种嵌入式应用量身打造，追求的是高可靠性、低功耗和高性价比。
          </p>
          <p>
            MCU 的核心魅力在于其“麻雀虽小，五脏俱全”的高度集成化。这种一体化设计极大地简化了硬件电路，缩小了产品体积，降低了功耗，并提升了系统的稳定性。从家里的洗衣机、微波炉，到汽车的引擎控制系统，再到工厂里的机器人手臂，MCU的身影无处不在，是现代电子设备的幕后英雄。
          </p>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">关键组件</h3>
            </div>
            <ul className="list-disc list-inside p-4 font-code text-sm">
              <li><strong>CPU (中央处理器):</strong> 微控制器的大脑，负责执行指令和处理数据。8051 使用的是一个8位的CISC（复杂指令集计算机）CPU。</li>
              <li><strong>RAM (随机存取存储器):</strong> 用于存储程序运行时的变量、临时数据和堆栈。掉电后数据会丢失。</li>
              <li><strong>ROM/Flash (只读存储器):</strong> 用于存储程序代码和固定数据。其内容在掉电后不会丢失。</li>
              <li><strong>I/O 端口 (输入/输出端口):</strong> 与外部世界（如传感器、执行器、显示器）交互的接口。</li>
              <li><strong>定时器/计数器:</strong> 用于产生精确的时间延迟、生成特定波形或对外部事件进行计数。</li>
              <li><strong>中断系统:</strong> 允许微控制器响应外部或内部发生的紧急事件，暂停当前任务，转而处理该事件，处理完毕后再返回原任务。</li>
              <li><strong>串行端口 (UART):</strong> 用于与其他设备（如计算机、其他微控制器）进行串行通信。</li>
            </ul>
          </div>
          <p>
            学习微控制器编程，其本质就是学习如何通过代码，像指挥家一样去调动和协调这些片上的硬件资源（外设），让它们精准地协同工作，最终实现千变万化的控制任务。这就像是学习一门能与硬件直接对话的语言。
          </p>
           <EnrichmentCard icon={<Lightbulb className="w-5 h-5" />} title="真实世界案例：智能家居的心脏">
              <p>我们日常使用的智能灯泡、智能插座，其核心往往就是一个小小的微控制器。</p>
              <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                  <li><strong>控制核心:</strong> MCU负责接收来自手机App或语音助手的指令（如通过Wi-Fi或蓝牙模块）。</li>
                  <li><strong>执行任务:</strong> 它精确控制LED驱动电路以实现调光、调色，或控制继电器来开关插座电源。</li>
                  <li><strong>状态上报:</strong> MCU还会将设备当前的状态（开关、亮度）反馈给App。</li>
                  <li><strong>核心价值:</strong> 这一切复杂的逻辑都由一个低成本、高效率的MCU完成，是智能家居得以普及的关键。</li>
              </ul>
          </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch1">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>MCU (微控制器) 是一个集成了<KeywordLink nodeId="cpu">CPU</KeywordLink>、<KeywordLink nodeId="memory">存储器</KeywordLink>和多种<KeywordLink nodeId="io">I/O外设</KeywordLink>于一体的单片微型计算机。</>,
          <>8051是一款经典的8位微控制器，采用<KeywordLink nodeId="harvard">哈佛结构</KeywordLink>，拥有独立的程序和数据存储空间。</>,
        ],
        difficultPoints: [
          <>深入理解“集成”的概念：它不仅是物理上的堆砌，更是功能上的协同。例如，<KeywordLink nodeId="timers">定时器</KeywordLink>的溢出可以自动触发<KeywordLink nodeId="interrupts">中断</KeywordLink>，无需CPU干预，这就是集成带来的高效。</>,
          <>区分MCU与MPU：MCU是自给自足的“系统”，自带RAM/ROM，强调控制；MPU是高性能“大脑”，需外挂RAM/ROM等芯片组成系统，强调计算。</>,
        ],
        commonMistakes: [
          <>将微控制器（MCU）与中央处理器（CPU）混为一谈。CPU只是MCU的一个核心组成部分。</>,
          <>认为所有微控制器的存储结构都和PC一样。8051的哈佛结构是其重要特点。</>,
        ],
        examPoints: [
          <>MCU的基本组成部分有哪些？（CPU、RAM、ROM、I/O口、定时器、中断系统等）</>,
          <>哈佛结构与冯·诺依曼结构的主要区别是什么？（程序与数据总线是否分离）</>,
        ],
      },
    },
    {
      id: "item-2",
      title: "第 2 章：8051 存储器结构",
      estimatedTime: "约 20 分钟",
      goals: {
        knowledge: ['理解哈佛结构与冯诺依曼结构的区别', '掌握8051内部RAM的区域划分和功能', '了解特殊功能寄存器(SFR)的作用'],
        skills: ['能够编写代码访问内部RAM的不同区域', '能够根据地址判断存储器类型（RAM/SFR）'],
        ideology: '结合国家“东数西算”工程，探讨数据存储在国家战略安全、数字经济发展中的基础性地位，强调安全、可靠的存储技术的重要性。'
      },
      content: (
        <>
          <p>
            8051 在架构上的一大特色是采用了<KeywordLink nodeId="harvard">哈佛结构</KeywordLink>。你可以把它想象成拥有两条独立的专用高速公路：一条专用于运输指令（从程序存储器到CPU），另一条专用于存取数据（在数据存储器和CPU之间）。这使得CPU可以同时进行取指令和读写数据两项操作，大大提升了工作效率。与之相对的是冯·诺依曼结构，它只有一条公路，指令和数据需要排队共享，效率稍逊一筹。
          </p>
          <p>
            <strong><KeywordLink nodeId="program_mem">程序存储器 (Program Memory, ROM)</KeywordLink>:</strong> 这里是存放用户程序代码的“图书馆”，指令被永久保存在这里。标准的 8051 内部有 4KB 的 ROM。当程序体积超过内部 ROM 容量时，可以通过将 EA (External Access) 引脚接地来访问外部 ROM，最大可扩展至 64KB。
          </p>
          <p>
            <strong><KeywordLink nodeId="data_mem">数据存储器 (Data Memory, RAM)</KeywordLink>:</strong> 这是存放程序运行时变量和临时数据的地方，就像是MCU的“草稿纸”，掉电后内容会丢失。它分为内部RAM和外部RAM。对于8051来说，<KeywordLink nodeId="internal_ram">内部 RAM</KeywordLink> 空间非常宝贵，标准型号只有128字节（00H - 7FH），但这寸土寸金的空间被精心划分为三个功能区：
          </p>
          <ol className="list-decimal list-inside ml-4 my-2">
              <li><strong><KeywordLink nodeId="register_banks">工作寄存器区 (00H - 1FH, 32字节)</KeywordLink>:</strong> 这是CPU最常用的“工具箱”，分为4个寄存器组（Bank 0-3），每组8个寄存器（R0-R7）。通过程序状态字（PSW）中的RS1和RS0位来选择当前使用哪个工具箱。</li>
              <li><strong><KeywordLink nodeId="bit_addr_ram">可位寻址区 (20H - 2FH, 16字节)</KeywordLink>:</strong> 这是MCU的“开关面板”，这16个字节（共128位）中的每一位都可以被单独置1或清0，非常适合用于存放布尔标志位。</li>
              <li><strong><KeywordLink nodeId="general_ram">通用 RAM 区 (30H - 7FH, 80字节)</KeywordLink>:</strong> 这是可自由使用的“储物间”，可用作普通的数据存储和堆栈空间。</li>
          </ol>
          <p>
            <strong><KeywordLink nodeId="sfr">特殊功能寄存器 (Special Function Registers, SFR)</KeywordLink>:</strong> 如果说MCU是一个功能强大的设备，那么SFR就是它的“控制面板”。这些寄存器专门用来配置和控制I/O口、定时器、串口等各种外设的工作状态。它们在物理上不属于通用RAM，但为了方便访问，被映射到了内部RAM的高128字节地址空间 (80H - FFH)。操作它们就像是按下控制面板上的各种开关和旋钮。
          </p>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">汇编代码示例：访问内部RAM</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch2, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch2}
              </code>
            </pre>
          </div>
          <EnrichmentCard icon={<Siren className="w-5 h-5" />} title="Mini-Project 构想：堆栈溢出警报器">
              <p>挑战自己，编写一个程序来直观地理解堆栈（Stack）的工作方式和“溢出”的危险。</p>
              <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                  <li><strong>核心思路:</strong> 程序的关键部分不断执行`PUSH`指令，将数据压入堆栈，同时监控堆栈指针`SP`的值。</li>
                  <li><strong>实现方法:</strong> 在主循环中，每次循环都`PUSH`一个寄存器（如A）。在循环之后，检查`SP`的值是否超过了预设的安全边界（例如 `7FH`）。</li>
                  <li><strong>触发警报:</strong> 如果`SP`超过边界，就点亮一个连接在P1口的“警报”LED灯。</li>
                  <li><strong>学习价值:</strong> 这个实验能让你深刻理解堆栈的增长方向、SP指针的作用，以及为何滥用递归或函数调用会导致灾难性的“堆栈溢出”错误。</li>
              </ul>
          </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch2">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>程序存储器（ROM）和数据存储器（RAM）地址空间独立，这是<KeywordLink nodeId="harvard">哈佛结构</KeywordLink>的核心。</>,
          <>内部RAM分为三个区域：<KeywordLink nodeId="register_banks">工作寄存器区</KeywordLink>、<KeywordLink nodeId="bit_addr_ram">可位寻址区</KeywordLink>和通用RAM区。</>,
          <><KeywordLink nodeId="sfr">SFR (特殊功能寄存器)</KeywordLink>用于控制外设，地址映射在内部RAM的高128字节。</>,
        ],
        difficultPoints: [
          <>高区地址二义性：内部RAM高128字节(80H-FFH)与<KeywordLink nodeId="sfr">SFR</KeywordLink>地址空间重叠。必须牢记：使用<KeywordLink nodeId="direct_addr">直接寻址</KeywordLink>（如 `MOV A, 80H`）访问的是SFR（P0口），而使用<KeywordLink nodeId="indirect_addr">间接寻址</KeywordLink>（如 `MOV R0, #80H; MOV A, @R0`）访问的是通用RAM。</>,
          <>堆栈操作的本质：堆栈指针SP永远指向“下一个可用的空位置”。`PUSH`操作是先将SP加一，再存入数据；`POP`操作是先取出数据，再将SP减一。</>,
        ],
        commonMistakes: [
          <>立即数与地址混淆：忘记立即数前的'#'号。`MOV A, #30H` 是将数值 30H 放入 A，而`MOV A, 30H`是将内部 RAM 30H 地址单元的内容放入 A。</>,
          <>高区RAM寻址错误：试图用 `MOV 81H, #55H` 向RAM的81H单元写数据，这实际上会错误地写入<KeywordLink nodeId="sfr">SFR</KeywordLink>（这里是SP堆栈指针），可能导致程序崩溃。必须用间接寻址。</>,
        ],
        examPoints: [
          <>8051内部RAM的三个区域及其地址范围和功能。</>,
          <>什么是SFR？它有什么作用？</>,
          <>数据指针<KeywordLink nodeId="dptr">DPTR</KeywordLink>是多少位的寄存器？（16位），它由哪两个8位SFR组成？（DPH和DPL）</>,
        ],
      },
    },
    {
      id: "item-3",
      title: "第 3 章：I/O 端口编程",
      estimatedTime: "约 15 分钟",
      goals: {
        knowledge: ['掌握8051四个I/O端口（P0-P3）的特性和区别', '理解“准双向口”和“漏极开路”的概念', '了解P3口的第二功能'],
        skills: ['能够编写代码实现对I/O口的读写操作', '能够正确连接外部上拉电阻以使用P0口', '能够通过编程点亮LED、读取按键状态'],
        ideology: 'I/O端口是连接数字世界与物理世界的桥梁。以此为引，探讨“一带一路”中的“数字丝绸之路”建设，理解信息基础设施互联互通对构建人类命运共同体的重大意义。'
      },
      content: (
        <>
          <p>
            如果说CPU是微控制器的大脑，那么四个8位的并行 <KeywordLink nodeId="io">I/O 端口</KeywordLink>（P0, P1, P2, P3）就是它的“感官和四肢”。它们是微控制器与外部世界（如按键、LED、传感器）进行信息交换和物理交互的桥梁，共提供了32个引脚。
          </p>
          <p>
            除了P1口，其他端口都身兼数职，拥有第二功能。在作为通用I/O口使用时，P1、P2、P3口都是**准双向口**，内部自带一个弱上拉电阻。这意味着，当你想从外部读取信号（作输入）时，必须先向该端口写入'1'，以“松开”内部的控制，让外部信号能够主导引脚的电平。
          </p>
          <ul className="list-disc list-inside space-y-2 my-2">
              <li><strong><KeywordLink nodeId="p0">P0 口 (地址 80H)</KeywordLink>:</strong> 这是一个“性格开放”的漏极开路口。用作通用I/O时，它需要外接上拉电阻才能可靠地输出高电平。它的主要第二职业是作为地址/数据复用总线，在访问外部存储器时非常繁忙。</li>
              <li><strong><KeywordLink nodeId="p1">P1 口 (地址 90H)</KeywordLink>:</strong> 这是最“单纯”的一个端口，是一个纯粹的8位准双向I/O口，没有其他第二功能。非常适合用于简单的开关控制和信号读取任务。</li>
              <li><strong><KeywordLink nodeId="p2">P2 口 (地址 A0H)</KeywordLink>:</strong> 性格与P1类似，但有第二功能：在访问大容量外部存储器时，它负责提供高8位的地址信息(A8-A15)。</li>
              <li><strong><KeywordLink nodeId="p3">P3 口 (地址 B0H)</KeywordLink>:</strong> 这是最“多才多艺”的端口。它的每个引脚都有一个重要的第二功能，是串行通信 (RXD, TXD)、外部中断 (INT0, INT1)、定时器脉冲输入 (T0, T1) 等关键任务的指定端口。</li>
          </ul>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">汇编代码示例：使P1口的LED闪烁</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch3, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch3}
              </code>
            </pre>
          </div>
          <p>
            记住一个关键原则：对端口进行写操作时，是改变端口锁存器的值；进行读操作时，是读取引脚的实际电平状态。读引脚前，先对该位写'1'，是确保输入功能正常的标准做法。
          </p>
          <EnrichmentCard icon={<FlaskConical className="w-5 h-5" />} title="Mini-Project 构想：交通信号灯">
              <p>这是一个经典的I/O应用项目，非常适合练习端口操作和延时编程。</p>
              <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                  <li><strong>硬件连接:</strong> 将三个LED（红、黄、绿）分别连接到P1口的三个不同引脚，如P1.0, P1.1, P1.2。</li>
                  <li><strong>逻辑流程:</strong> 编写一个主循环，按照“绿灯亮 → 绿灯闪烁 → 黄灯亮 → 红灯亮”的顺序来控制三个LED。</li>
                  <li><strong>精髓所在:</strong> 你需要为不同的亮灯和闪烁阶段编写精确的延时子程序。</li>
                  <li><strong>学习价值:</strong> 完美地练习了对I/O口的位操作、循环编程和软件延时，是许多复杂时序控制系统的基础。</li>
              </ul>
          </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch3">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>四个8位I/O端口（<KeywordLink nodeId="p0">P0</KeywordLink>, <KeywordLink nodeId="p1">P1</KeywordLink>, <KeywordLink nodeId="p2">P2</KeywordLink>, <KeywordLink nodeId="p3">P3</KeywordLink>）是MCU与外部世界交互的接口。</>,
          <>P0口是漏极开路，用作输出时需外接上拉电阻才能输出高电平。</>,
          <>P1, P2, P3是准双向口，内部有弱上拉，作输入时需先对该位写1。</>,
        ],
        difficultPoints: [
          <>“读-修改-写”操作的潜在问题：对端口的部分位进行操作时（如`SETB P1.0`），CPU会先读整个P1口，修改第0位后再整个写回。如果此时P1.1引脚被外部电路拉低，这个低电平会被读回并最终被“固化”，导致P1.1意外变为低电平输出。这是准双向口的一个固有缺陷。</>,
        ],
        commonMistakes: [
          <>使用P0口作通用I/O时，忘记外接上拉电阻，导致无法输出高电平。</>,
          <>将P1/P2/P3口用作输入时，忘记先向该端口位写入'1'，导致读到错误的低电平。</>,
        ],
        examPoints: [
          <>P0, P1, P2, P3四个端口的结构特性和主要区别。</>,
          <>P3口各引脚的第二功能？（P3.0:RXD, P3.1:TXD, P3.2:INT0, P3.3:INT1, P3.4:T0, P3.5:T1, P3.6:WR, P3.7:RD）</>,
        ],
      },
    },
    {
      id: "item-4",
      title: "第 4 章：8051 汇编语言基础",
      estimatedTime: "约 30 分钟",
      goals: {
        knowledge: ['理解汇编语言的作用和基本格式', '掌握五种核心寻址方式（立即、直接、寄存器、间接、变址）', '熟悉常用伪指令（ORG, END, DB）的用法'],
        skills: ['能够阅读简单的汇编代码', '能够使用MOV, ADD等基本指令编写简单的数据操作程序', '能够使用DJNZ指令构建循环'],
        ideology: '学习汇编语言需要极致的严谨和对细节的精确把控。以此培养学生的“工匠精神”，理解在核心技术领域精益求精、追求卓越的时代价值。'
      },
      content: (
        <>
           <p>
             <KeywordLink nodeId="assembly">汇编语言</KeywordLink>是CPU能直接理解的机器指令的文本表示，是硬件的“母语”。虽然C语言等高级语言更易于编写和维护，但学习汇编能让你深入微控制器的内心，理解每一条指令如何影响硬件，从而在性能和代码体积要求极致的场景下写出最精炼高效的代码。
          </p>
          <p>
              指令的核心在于如何找到它要操作的数据，这就是<strong><KeywordLink nodeId="addressing_modes">寻址方式</KeywordLink></strong>。8051提供了多种灵活的寻址方式，就像给了你不同的方法去获取一个东西：
          </p>
           <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">寻址方式示例</h3>
            </div>
            <ul className="list-disc list-inside p-4 font-code text-sm">
              <li><strong><KeywordLink nodeId="immediate_addr">立即寻址</KeywordLink>:</strong> “我直接给你钱”，操作数就跟在指令后面。 e.g., <code className="language-asm">MOV A, #30H</code></li>
              <li><strong><KeywordLink nodeId="direct_addr">直接寻址</KeywordLink>:</strong> “钱在XX号信箱里”，指令里直接给出了数据所在的内存地址。 e.g., <code className="language-asm">MOV A, 30H</code></li>
              <li><strong><KeywordLink nodeId="register_addr">寄存器寻址</KeywordLink>:</strong> “钱在你的左边口袋（R0）里”，数据就在指定的寄存器中。 e.g., <code className="language-asm">MOV A, R0</code></li>
              <li><strong><KeywordLink nodeId="indirect_addr">寄存器间接寻址</KeywordLink>:</strong> “存放钱的信箱号码写在了你的左手心（R0）里”，数据地址存储在R0或R1寄存器中。 e.g., <code className="language-asm">MOV A, @R0</code></li>
              <li><strong>变址寻址:</strong> “去书架（DPTR）上第A本书里找”，常用于查表。 e.g., <code className="language-asm">MOVC A, @A+DPTR</code></li>
            </ul>
          </div>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">代码示例：汇编实现加法</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch4, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch4}
              </code>
            </pre>
          </div>
          <p>
              在汇编中，`MOV` 是最基本的数据搬运工。`#` 符号是立即数的标志，千万不能漏掉。`ORG` 和 `END` 这种被称为伪指令，它们不被CPU执行，而是给汇编器看的“注释”，用于指导编译过程。
          </p>
          <EnrichmentCard icon={<Zap className="w-5 h-5" />} title="真实世界案例：高性能引导加载程序 (Bootloader)">
              <p>虽然现代嵌入式开发多用C语言，但在对性能和体积要求极为苛刻的场景，汇编语言仍是王者，最典型的就是Bootloader。</p>
              <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                  <li><strong>极致速度:</strong> Bootloader是设备上电后运行的第一段代码，它的任务是快速初始化最基本的硬件（如时钟、内存），然后加载主应用程序。这个过程必须快，汇编能实现最直接的硬件控制，无任何额外开销。</li>
                  <li><strong>极致体积:</strong> Bootloader通常存放在一个容量很小的专用Flash区域，代码必须极度精简。汇编指令与机器码一一对应，能让开发者对每一个字节都了如指掌。</li>
                  <li><strong>学习价值:</strong> 理解汇编的重要性，不在于用它写整个项目，而在于拥有在关键时刻深入底层、榨干硬件性能的“杀手锏”能力。</li>
              </ul>
          </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch4">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>掌握五种核心<KeywordLink nodeId="addressing_modes">寻址方式</KeywordLink>：立即、直接、寄存器、寄存器间接、变址。</>,
          <>熟悉常用指令：数据传送(`MOV`, `MOVC`, `PUSH`, `POP`)、算术运算(`ADD`, `ADDC`, `INC`, `DEC`)、逻辑运算(`ANL`, `ORL`, `XRL`, `CPL`, `RR`)、控制转移(`SJMP`, `LJMP`, `ACALL`, `LCALL`, `RET`, `RETI`, `DJNZ`, `CJNE`)。</>,
        ],
        difficultPoints: [
          <>理解<KeywordLink nodeId="indirect_addr">寄存器间接寻址</KeywordLink>（`@R0`）和变址寻址（`@A+DPTR`）的区别和应用场景，后者常用于查表。</>,
          <>`MOVC` vs `MOV`：`MOVC`的'C'代表'Code'，专门用于从程序存储器（ROM）中读取数据，如查七段码表。 `MOV` 则用于RAM和SFR之间的数据转移。</>,
        ],
        commonMistakes: [
          <>直接寻址和立即寻址混淆，特别是`#`号的使用。</>,
          <>在需要从ROM查表（如七段码）时，错误地使用`MOV`指令代替`MOVC`。</>,
        ],
        examPoints: [
          <>根据给定的指令，判断其采用的寻址方式。</>,
          <>`DJNZ`指令的功能和应用（常用于构建延时循环）。</>,
          <>伪指令`ORG`, `END`, `DB`的作用。</>,
        ],
      },
    },
    {
      id: "item-5",
      title: "第 5 章：定时器/计数器",
      estimatedTime: "约 25 分钟",
      goals: {
        knowledge: ['理解定时器/计数器的基本工作原理', '掌握TMOD和TCON寄存器的配置方法', '熟悉定时器四种工作模式，重点是模式1和模式2'],
        skills: ['能够计算不同晶振频率下的定时初值', '能够编写代码使用定时器产生精确的延时', '能够使用定时器生成指定频率的方波'],
        ideology: '精确的定时是许多“大国重器”如高铁、电网、北斗导航系统的基石。学习定时器，感悟“分秒不差”的严谨作风对国家重大工程的决定性作用。'
      },
      content: (
        <>
          <p>
            <KeywordLink nodeId="timers">定时器/计数器</KeywordLink>是微控制器的“节拍器”和“计数器”。它既可以用来产生精确到微秒的时间延迟（定时器模式），也可以用来对外部发生的脉冲事件进行计数（计数器模式）。标准的8051内置了两个16位的定时器/计数器：T0和T1。
          </p>
          <p>
            它们的工作模式由<strong><KeywordLink nodeId="tmod">TMOD</KeywordLink></strong>寄存器这个“模式选择旋钮”来设定。TMOD是一个8位寄存器，高4位控制T1，低4位控制T0。其中的C/T位决定了它是作为定时器（C/T=0，对内部机器周期计数）还是计数器（C/T=1，对外部T0/T1引脚的脉冲计数）。
          </p>
          <ul className="list-disc list-inside ml-4 my-2">
            <li><strong>模式0:</strong> 13位定时器/计数器模式，较少使用。</li>
            <li><strong><KeywordLink nodeId="timer_mode1">模式1</KeywordLink>:</strong> 16位定时器/计数器模式。这是最灵活、最常用的模式，计数范围可达65536。</li>
            <li><strong><KeywordLink nodeId="timer_mode2">模式2</KeywordLink>:</strong> 8位自动重装载模式。当计数溢出后，能自动从THx寄存器中重新加载初值，非常适合用于生成周期性的信号，比如串口通信的波特率。</li>
            <li><strong>模式3:</strong> T0可拆分为两个独立的8位定时器，而T1在此模式下停止工作。</li>
          </ul>
          <p>
            定时器的启动、停止（TRx位）以及溢出状态的查询（TFx位）则由<strong><KeywordLink nodeId="tcon">TCON</KeywordLink></strong>这个“启停开关和状态指示灯”来管理。
          </p>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">汇编代码示例：定时器0模式1产生中断</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch5, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch5}
              </code>
            </pre>
          </div>
          <p>
            定时器的核心思想是“溢出”。我们先给它设定一个初始计数值，然后启动它。它会随着每个机器周期自动加1，当计数值从全1（如FFFFH）变为0时，就发生了一次“溢出”。这个溢出事件会触发TFx标志位置1，并可以进一步触发中断，告诉我们预设的时间已经到了。
          </p>
           <EnrichmentCard icon={<FlaskConical className="w-5 h-5" />} title="Mini-Project 构想：呼吸灯">
              <p>挑战自己，将本章所学的定时器中断与I/O操作结合，利用PWM（脉冲宽度调制）技术，创造一个让LED亮度平滑变化的“呼吸灯”效果。</p>
              <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                  <li><strong>核心思路:</strong> 在一个固定的短周期内（如10ms），通过改变高电平持续的时间（占空比）来控制LED的平均亮度。</li>
                  <li><strong>实现方法:</strong> 使用一个高速的定时器中断。在中断服务程序中，用一个变量来控制引脚电平的翻转时刻，从而动态调整占空比。</li>
                  <li><strong>学习价值:</strong> 这是电机速度控制、模拟信号输出等高级应用的基础，能极大加深对定时器精确控制能力的理解。</li>
              </ul>
          </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch5">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>定时器/计数器的本质是加1计数器，其核心工作方式是“计数溢出”。</>,
          <>通过配置 <KeywordLink nodeId="tmod">TMOD</KeywordLink> 寄存器来选择工作模式，通过 <KeywordLink nodeId="tcon">TCON</KeywordLink> 寄存器来控制启停和查询溢出标志。</>,
          <>模式1是16位定时器，模式2是8位自动重装载定时器，后者常用于生成波特率。</>,
        ],
        difficultPoints: [
          <>定时初值的精确计算：`定时时间 = (2^位数 - 初值) × 机器周期`。对于12MHz晶振，机器周期为1μs。若要定时1ms（1000μs），16位模式(65536)下的初值 = 65536 - 1000 = 64536 (FC18H)。</>,
          <>晶振频率、机器周期和定时时间三者之间的换算关系。</>,
        ],
        commonMistakes: [
          <>忘记在启动定时器（`SETB TRx`）之前加载初值到`THx`和`TLx`。</>,
          <>在查询法中使用溢出标志`TFx`后，忘记用软件将其清零（`CLR TFx`）。</>,
          <>在中断法中使用模式1时，忘记在<KeywordLink nodeId="isr">中断服务程序</KeywordLink>里为THx和TLx重装初值，导致后续定时周期不准确。</>,
        ],
        examPoints: [
          <>`TMOD`寄存器各位的定义和功能。</>,
          <>定时器模式1和模式2的区别及各自的应用场景。</>,
          <>给定晶振频率和定时时间，计算16位模式下的定时初值`THx`和`TLx`。</>,
        ],
      },
    },
    {
      id: "item-6",
      title: "第 6 章：中断系统",
      estimatedTime: "约 25 分钟",
      goals: {
        knowledge: ['理解中断的概念和相对于轮询的优势', '熟记8051的5个中断源及其优先级和中断向量', '掌握IE和IP寄存器的配置方法'],
        skills: ['能够编写完整的中断服务程序（ISR）', '能够独立配置并实现一个外部中断或定时器中断', '理解RETI指令的特殊作用'],
        ideology: '中断系统是高效应急响应的核心。结合我国在抗震救灾、疫情防控等重大突发事件中的高效组织和响应能力，理解中断机制在关键时刻“集中力量办大事”的制度优势。'
      },
      content: (
        <>
           <p>
              <KeywordLink nodeId="interrupts">中断</KeywordLink>是微控制器处理突发事件的高效机制。你可以把它想象成一个“门铃”。当你在专心做一件事（执行主程序）时，如果门铃响了（中断发生），你会立刻放下手中的事，去开门处理（执行中断服务程序），处理完后再回来继续刚才的工作。
          </p>
          <p>
              这种机制远比你每隔几秒就主动跑去看一下有没有人按门铃（轮询方式）要高效得多。标准的8051有5个<KeywordLink nodeId="int_sources">中断源</KeywordLink>，每个中断源都像一个不同的门铃，对应一个固定的“开门程序”入口地址（中断向量）和默认的响应优先级：
          </p>
           <ul className="list-decimal list-inside ml-4 my-2">
              <li><strong><KeywordLink nodeId="ext_int0">外部中断0 (IE0)</KeywordLink>:</strong> 地址 0003H, 优先级最高，像是“贵宾通道”。</li>
              <li><strong><KeywordLink nodeId="timer0_int">定时器0溢出 (TF0)</KeywordLink>:</strong> 地址 000BH，是内部的“闹钟”。</li>
              <li><strong><KeywordLink nodeId="ext_int1">外部中断1 (IE1)</KeywordLink>:</strong> 地址 0013H，另一个外部事件通道。</li>
              <li><strong><KeywordLink nodeId="timer1_int">定时器1溢出 (TF1)</KeywordLink>:</strong> 地址 001BH，第二个内部“闹钟”。</li>
              <li><strong>串行端口 (RI/TI):</strong> 地址 0023H, 优先级最低，处理通信数据收发。</li>
          </ul>
          <p>
              要使用中断，必须进行三步设置：首先打开总中断开关EA（在<strong><KeywordLink nodeId="ie">IE</KeywordLink></strong>寄存器中），然后打开对应中断源的分开关（也在IE寄存器中），最后编写好对应的<strong><KeywordLink nodeId="isr">中断服务程序 (ISR)</KeywordLink></strong>。如果需要，还可以通过<strong><KeywordLink nodeId="ip">IP (Interrupt Priority)</KeywordLink></strong>寄存器调整中断的优先级。
          </p>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">汇编代码示例：外部中断0服务程序</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch6, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch6}
              </code>
            </pre>
          </div>
          <p>
              中断服务程序的最后一条指令必须是 `RETI`（中断返回）。它不仅会让CPU返回到被中断的地方，还会恢复中断系统的内部逻辑，使其能响应新的、同级或更高级的中断请求。
          </p>
           <EnrichmentCard icon={<Siren className="w-5 h-5" />} title="真实世界案例：工业安全急停">
              <p>在自动化生产线、电梯控制系统等安全关键领域，紧急停止按钮是保障人员和设备安全的第一道防线。</p>
              <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                  <li><strong>实现方式:</strong> 急停按钮通常连接到一个高优先级的外部中断引脚（如INT0）。</li>
                  <li><strong>工作流程:</strong> 正常情况下，主程序循环执行生产任务。一旦按下急停按钮，会立即触发中断。</li>
                  <li><strong>中断服务:</strong> ISR（中断服务程序）会以最快速度执行关键的关停操作，如切断电机电源、启动制动器等，完全无视主程序当前正在做什么。</li>
                  <li><strong>核心价值:</strong> 这充分体现了中断机制的“抢占式”特性，是实现可靠、快速应急响应的基石。</li>
              </ul>
          </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch6">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>中断是处理突发事件的高效机制，优于轮询。</>,
          <>使用中断必须配置<KeywordLink nodeId="ie">IE寄存器</KeywordLink>（EA总开关和各分开关）并编写<KeywordLink nodeId="isr">中断服务程序</KeywordLink>。</>,
          <>8051有5个<KeywordLink nodeId="int_sources">中断源</KeywordLink>，每个源有固定的中断向量地址和自然优先级。</>,
          <>中断服务程序的最后一条指令必须是`RETI`。</>,
        ],
        difficultPoints: [
          <>中断响应过程：1.中断源发出请求（如TF0置1）。2.CPU在当前指令执行完后，检测中断标志。3.若该中断被允许且优先级最高，CPU保护断点（PC入栈）。4.硬件清除某些中断标志（如TF0/TF1不会自动清，但TI/RI会）。5.CPU跳转到对应的中断向量地址。</>,
          <>中断优先级：当多个中断同时发生时，CPU如何根据自然优先级和<KeywordLink nodeId="ip">IP寄存器</KeywordLink>设置进行裁决。</>,
        ],
        commonMistakes: [
          <>忘记打开总中断开关`EA`，导致所有中断都无法响应。</>,
          <>中断服务程序结尾错误地使用了`RET`而不是`RETI`，这将导致中断系统状态混乱，无法响应新的同级中断。</>,
          <>对于电平触发方式的外部中断（ITx=0），若<KeywordLink nodeId="isr">中断服务程序</KeywordLink>没有撤销外部中断源信号，当中断返回后，低电平依然存在，会造成CPU反复进入中断，程序卡死。</>,
        ],
        examPoints: [
          <>5个中断源及自然优先级：<KeywordLink nodeId="ext_int0">外部中断0</KeywordLink> {'>'} <KeywordLink nodeId="timer0_int">定时器0</KeywordLink> {'>'} <KeywordLink nodeId="ext_int1">外部中断1</KeywordLink> {'>'} <KeywordLink nodeId="timer1_int">定时器1</KeywordLink> {'>'} <KeywordLink nodeId="serial_int">串行口中断</KeywordLink>。</>,
          <>`IE`和`IP`寄存器中各位的功能。</>,
          <>`RETI`指令和`RET`指令的关键区别是什么？</>,
        ],
      },
    },
    {
      id: "item-7",
      title: "第 7 章：LED 动态显示",
      estimatedTime: "约 20 分钟",
      goals: {
        knowledge: ['理解视觉暂留效应', '掌握动态扫描中“位选”和“段选”的概念', '了解“消隐”操作的重要性'],
        skills: ['能够设计和编写多位数码管的动态扫描程序', '能够使用查表法获取7段数码管的字形码', '能够独立完成硬件连接和软件调试'],
        ideology: '联想国家大型庆典活动中宏伟壮观的LED背景屏幕。探讨动态显示技术如何服务于国家形象的展示和民族文化自信的表达，理解技术服务于社会、文化的功能。'
      },
      content: (
        <>
          <p>
            <KeywordLink nodeId="led_scan">LED动态显示</KeywordLink>技术巧妙地利用了人眼的<strong>视觉暂留</strong>效应，就像电影胶片快速播放形成连续动画一样。我们通过分时复用I/O口，在极短的时间内轮流点亮单个或单列LED。只要扫描速度足够快（通常大于50Hz），人眼就会“脑补”出所有LED同时稳定亮起的假象。这种方法能用极少的I/O口驱动大量的LED，是节省硬件资源的经典技巧。
          </p>
          <p>
            以驱动多个7段数码管为例，其核心是“位选”和“段选”的配合。<strong>段选</strong>负责控制“显示什么内容”，我们将所有数码管的同名段（如所有a段）并联，由一个I/O口（如P0）统一控制。<strong>位选</strong>负责控制“在哪个位置显示”，每个数码管的公共端（共阴极或共阳极）由另一个I/O口（如P2）的单个引脚独立控制。
          </p>
          <p>
            扫描过程就像一个快速的舞台灯光秀：首先，位选口选中1号数码管（给它通电）；接着，段选口输出1号要显示的字形码，点亮它；短暂延时（如1毫秒）后，立即关闭所有段选输出（这个操作叫**消隐**，是防止切换时留下模糊“鬼影”的关键一步）；然后，位选口切换到2号数码管，段选口输出2号的字形码...如此高速循环，一幅完整的画面就在我们眼中形成了。
          </p>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">汇编代码示例：4位数码管动态扫描</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch7, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch7}
              </code>
            </pre>
          </div>
           <EnrichmentCard icon={<FlaskConical className="w-5 h-5" />} title="Mini-Project 构想：智能时钟">
                <p>挑战自己，将本章所学的动态扫描技术与第5章的定时器中断结合起来，创造一个功能完整的6位数字时钟！</p>
                <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                    <li><strong>核心功能:</strong> 使用定时器中断（例如每10ms一次）来更新时间和驱动数码管扫描。</li>
                    <li><strong>扩展功能:</strong> 添加按键（参考第3章）来调整时间；增加闹钟功能。</li>
                    <li><strong>学习价值:</strong> 这个项目将综合运用中断、定时器、I/O操作和查表等核心知识，是检验您综合实践能力的绝佳方式。</li>
                </ul>
            </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch7">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>动态扫描利用了人眼的“视觉暂留”效应，通过分时复用I/O口来驱动多个显示设备。</>,
          <>核心是“位选”（选择哪个亮）和“段选”（控制亮什么内容）的快速、循环切换。</>,
          <>“消隐”操作（切换位选前关闭段选）是防止显示“鬼影”的关键步骤。</>,
        ],
        difficultPoints: [
          <>设计高效、无闪烁的扫描程序，需要合理安排位选、段选、延时、消隐的顺序。</>,
          <>共阴极和共阳极数码管的段码和位选码逻辑完全相反。</>,
        ],
        commonMistakes: [
          <>忘记或错误地进行消隐操作，导致数码管显示模糊的“鬼影”。</>,
          <>扫描延时时间不当：延时过长导致肉眼可见的闪烁（刷新率低于50Hz）；延时过短导致亮度不足，因为每个LED的点亮时间太短。</>,
          <>混淆共阴极和共阳极的编码，导致显示错误的字符。</>,
        ],
        examPoints: [
          <>动态扫描的工作原理是什么？</>,
          <>在动态扫描程序中，“消隐”的作用是什么？</>,
          <>获取七段码通常使用哪条查表指令？（`MOVC A, @A+DPTR`）</>,
        ],
      },
    },
    {
      id: "item-8",
      title: "第 8 章：模数转换器 (ADC)",
      estimatedTime: "约 15 分钟",
      goals: {
        knowledge: ['理解模拟信号和数字信号的区别', '掌握ADC的基本工作原理和关键指标（如分辨率）', '熟悉与ADC0804芯片交互的时序和控制引脚'],
        skills: ['能够编写程序启动ADC转换、查询转换状态并读取结果', '能够将读取到的数字量进行简单的处理和显示'],
        ideology: '探讨ADC技术在“美丽中国”建设中的应用，如环境监测（空气、水质），以及在精准农业中助力乡村振兴，将技术学习与国家生态文明建设和发展战略结合。'
      },
      content: (
        <>
          <p>
            <KeywordLink nodeId="adc_app">模数转换器（ADC）</KeywordLink>是连接现实物理世界与微控制器数字世界的关键“翻译官”。现实世界中的信号，如温度、光强、声音，都是连续变化的模拟信号，而微控制器只能理解0和1组成的数字信号。ADC的作用就是将这些模拟电压精准地转换成数字值。
          </p>
          <p>
            ADC的<strong>分辨率</strong>（如8位、10位）是其核心指标，决定了“翻译”的精细程度。一个8位的ADC能将输入电压范围（如0-5V）划分成2^8=256个等级。分辨率越高，测量结果就越精确。标准的8051本身不带ADC，通常需要外接专用的ADC芯片，如经典的 **ADC0804**。
          </p>
           <p>
            与ADC0804的典型交互流程就像一次正式的问询：
           </p>
            <ol className="list-decimal list-inside ml-4 my-2">
              <li><strong>启动转换 (提问):</strong> 给ADC的WR引脚一个负脉冲，相当于对ADC说：“请开始测量当前的电压”。</li>
              <li><strong>等待转换完成 (等待回答):</strong> 转换需要时间。我们可以不断查询INTR引脚的状态，当它变为低电平时，表示ADC已经“想好了答案”。</li>
              <li><strong>读取结果 (听取答案):</strong> 确认转换完成后，将RD引脚拉低，ADC就会把转换好的8位数字结果放到数据总线上，微控制器此时可以读取这个值。</li>
              <li><strong>结束读取 (结束对话):</strong> 读取完毕后，将RD引脚拉高，让数据总线恢复空闲状态。</li>
            </ol>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">汇编代码示例：读取ADC0804</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch8, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch8}
              </code>
            </pre>
          </div>
          <EnrichmentCard icon={<FlaskConical className="w-5 h-5" />} title="Mini-Project 构想：简易数字电压表">
              <p>将ADC的模拟输入与数码管的数字输出相结合，创造一个有实际用途的测量工具。</p>
              <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                  <li><strong>核心思路:</strong> 将一个可变电阻（滑动变阻器）连接到ADC0804的输入端，作为模拟电压源。</li>
                  <li><strong>数据处理:</strong> 8051读取ADC转换后的8位数字结果。你需要编写一小段代码，将这个二进制数转换为两个十进制数（如，将`FFH=255`转换为`2`、`5`、`5`）。</li>
                  <li><strong>结果显示:</strong> 使用第7章学到的数码管动态扫描技术，将转换后的十进制数显示在3个数码管上。</li>
                  <li><strong>学习价值:</strong> 这个项目完美地串联了模拟信号输入、数字处理和数字输出三个环节，是构建一个完整测控系统的绝佳实践。</li>
              </ul>
          </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch8">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>ADC的作用是将连续的模拟信号转换为离散的数字信号。</>,
          <>与ADC0804的交互流程为：启动转换（WR脉冲）、等待转换结束（查询INTR）、读取结果（RD有效）。</>,
          <>ADC的关键指标是分辨率，它决定了转换的精度。</>,
        ],
        difficultPoints: [
          <>理解ADC0804控制引脚 `WR`（写）、`RD`（读）、`INTR`（中断）的电平有效性（低电平有效）。</>,
          <>数字量到物理量的转换：例如，对于一个8位ADC，参考电压为5V，若读到的数字值为N，则对应的模拟电压为 `V = (N / 255) * 5V`。</>,
        ],
        commonMistakes: [
          <>启动转换（拉低WR）后，没有等待足够长的时间或没有查询INTR引脚，就去读取数据，导致读到上一次的结果。</>,
          <>在读取数据前，忘记将数据端口（如P1）设置为输入模式。</>,
        ],
        examPoints: [
          <>ADC的基本功能是什么？</>,
          <>简述使用查询法与ADC0804进行一次完整数据采集的步骤。</>,
        ],
      },
    },
    {
      id: "item-9",
      title: "第 9 章：串行通信 (UART)",
      estimatedTime: "约 20 分钟",
      goals: {
        knowledge: ['理解串行通信和并行通信的差异', '掌握UART数据帧的结构（起始位、数据位、停止位）', '熟悉SCON和SBUF寄存器的作用'],
        skills: ['能够配置定时器1生成标准波特率', '能够编写代码实现单个字符的发送和接收', '能够通过查询或中断方式处理串行通信'],
        ideology: '以我国自主研发的“北斗”全球卫星导航系统为例，讲解串行通信在空天技术、国家信息主权中的关键作用，增强学生的民族自豪感和科技自信心。'
      },
      content: (
        <>
          <p>
            <KeywordLink nodeId="uart">串行通信</KeywordLink>是微控制器与外部世界（如PC、GPS模块、蓝牙模块）进行远距离数据交换的生命线。与一次传输8位数据的并行通信（像8车道高速公路）不同，串行通信（UART）像一条单车道小路，数据一位一位地按顺序传输。虽然速度较慢，但它只需要两根线（TXD发送，RXD接收），极大地节省了硬件引脚和布线成本。
          </p>
           <p>
            为了保证收发双方能正确同步，异步通信的数据被打包成一个“数据帧”。这个数据帧有固定的格式：以1位<strong>起始位</strong>（低电平）开始，紧跟着8位数据位，最后以1位<strong>停止位</strong>（高电平）结束。双方必须事先约定好相同的传输速率，即<strong>波特率</strong>（每秒传输的位数）。
          </p>
          <p>
            在8051中，这个通信过程由串行端口硬件自动完成，我们只需要配置好几个关键的“开关”：<strong><KeywordLink nodeId="scon">SCON</KeywordLink></strong>（串行口控制寄存器）用于设定工作模式（通常用模式1），并允许接收。而数据收发的“中转站”是<strong><KeywordLink nodeId="sbuf">SBUF</KeywordLink></strong>（串行口数据缓冲寄存器）。有趣的是，SBUF在物理上是两个独立的寄存器（一个只写用于发送，一个只读用于接收），但它们共享同一个SFR地址99H。
          </p>
          <p>
            稳定波特率的生成通常由<KeywordLink nodeId="timers">定时器1</KeywordLink>在<KeywordLink nodeId="timer_mode2">模式2</KeywordLink>（8位自动重装载）下完成。选择特定的晶振（如11.0592MHz）并给TH1设置特定的初值（如0FDH），就能精确地得到9600等标准波特率。
          </p>
          <div className="rounded-lg bg-background/50 my-6">
            <div className="flex items-center justify-between px-4 py-2 border-b">
                <h3 className="text-sm font-semibold text-primary">汇编代码示例：发送字符'A'</h3>
                <Button variant="ghost" size="icon" className="h-8 w-8" onClick={(e) => handleCopy(codeSnippets.ch9, e)}>
                    <Copy className="h-4 w-4"/>
                    <span className="sr-only">复制代码</span>
                </Button>
            </div>
            <pre className="font-code text-sm p-4 overflow-x-auto">
              <code className="language-asm">
{codeSnippets.ch9}
              </code>
            </pre>
          </div>
          <p>
            当一个字节被完全发送出去后，SCON中的发送中断标志TI会自动置1，通知我们可以发送下一个字节。同样，当接收到一个完整的字节后，接收中断标志RI会被置1，通知我们可以去SBUF中读取新数据了。
          </p>
           <EnrichmentCard icon={<Globe className="w-5 h-5" />} title="真实世界案例：物联网 (IoT) 温湿度传感器">
                <p>本章学习的UART串行通信是物联网设备数据传输的基石。想象一个基于8051的无线温湿度监测节点：</p>
                <ul className="list-disc list-inside mt-2 space-y-1 pl-4">
                    <li><strong>数据采集:</strong> 8051通过I/O口连接DHT11等温湿度传感器，读取数据。</li>
                    <li><strong>数据发送:</strong> 8051将处理后的温湿度数据，通过它的TXD引脚（P3.1）发送给一个蓝牙或Wi-Fi模块（如ESP8266）。</li>
                    <li><strong>无线传输:</strong> 无线模块接收到串行数据后，将其打包并通过无线网络发送到云服务器或手机APP。</li>
                    <li><strong>应用场景:</strong> 这种低成本、低功耗的方案被广泛应用于智能家居、智慧农业大棚、仓库环境监控等领域，是“产教融合”的典型案例。</li>
                </ul>
            </EnrichmentCard>
           <div className="mt-6 flex justify-end">
              <Button asChild variant="outline" size="sm">
                  <Link href="/knowledge-graph?chapter=ch9">
                      <Share2 className="mr-2 h-4 w-4" />
                      在知识图谱中探索
                  </Link>
              </Button>
          </div>
        </>
      ),
      highlights: {
        keyPoints: [
          <>串行通信按位传输数据，节省I/O线；异步通信通过固定的数据帧格式（起始位+数据位+停止位）来同步。</>,
          <>通过配置<KeywordLink nodeId="scon">SCON寄存器</KeywordLink>设置串行口工作模式（常用模式1）。</>,
          <>数据收发通过<KeywordLink nodeId="sbuf">SBUF寄存器</KeywordLink>，它物理上是两个独立的收/发缓冲器，但共享同一地址。</>,
          <>波特率的生成通常依赖<KeywordLink nodeId="timers">定时器1</KeywordLink>的<KeywordLink nodeId="timer_mode2">模式2</KeywordLink>（8位自动重装）。</>,
        ],
        difficultPoints: [
          <>使用特定晶振（如11.0592MHz）和特定初值来精确生成标准波特率的计算和原理。</>,
          <>`TI`（发送中断）和`RI`（接收中断）标志位的区别和使用时机。</>,
        ],
        commonMistakes: [
          <>发送数据时，将数据写入`SBUF`后，没有等待`TI`标志位置1，就立即发送下一字节，导致数据丢失。</>,
          <>在查询法中使用`TI`或`RI`标志后，忘记用软件将其清零。</>,
        ],
        examPoints: [
          <>串行通信的一帧数据包含哪些部分？</>,
          <>`SCON`寄存器中`SM0/SM1`（模式选择）和`REN`（允许接收）位的作用。</>,
          <>`TI`和`RI`标志位分别在什么时候由硬件置1？</>,
        ],
      },
    },
  ];

  const filteredChapters = useMemo(() => {
    // This logic is complex and relies on the content which is JSX, not simple text.
    // A simple text search on title is more robust here.
    const query = searchQuery.toLowerCase().trim();
    if (!query) {
      return chaptersData;
    }
    return chaptersData.filter(chapter => 
      chapter.title.toLowerCase().includes(query)
    );
  }, [searchQuery]);

  const accordionType = searchQuery ? "multiple" : "single";
  const accordionDefaultValue = useMemo(() => {
    if (searchQuery) {
        return filteredChapters.map(c => c.id);
    }
    // Try to find the chapter from the URL hash
    if (typeof window !== "undefined") {
      const hash = window.location.hash;
      if (hash) {
        const chapterId = hash.substring(1); // remove #
        if (chaptersData.some(c => c.id === chapterId)) {
          return chapterId;
        }
      }
    }
    return "item-1";
  }, [searchQuery, filteredChapters]);


  return (
    <div className="flex flex-col gap-6">
      <div className="flex flex-wrap gap-4 justify-end items-center">
        <div className="relative w-full max-w-sm">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
          <Input 
            placeholder="仅搜索章节标题..." 
            className="pl-9"
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
          />
        </div>
      </div>
      
      <Card>
        <CardHeader>
          <CardTitle>课程内容</CardTitle>
        </CardHeader>
        <CardContent>
           {accordionType === 'single' ? (
            <Accordion 
              key={searchQuery || (Array.isArray(accordionDefaultValue) ? accordionDefaultValue.join(',') : accordionDefaultValue)} 
              type="single" 
              defaultValue={Array.isArray(accordionDefaultValue) ? accordionDefaultValue[0] : accordionDefaultValue} 
              collapsible
              className="w-full"
            >
           ) : (
            <Accordion 
              key={searchQuery || (Array.isArray(accordionDefaultValue) ? accordionDefaultValue.join(',') : accordionDefaultValue)} 
              type="multiple" 
              defaultValue={Array.isArray(accordionDefaultValue) ? accordionDefaultValue : [accordionDefaultValue]} 
              className="w-full"
            >
           )}
            {filteredChapters.length > 0 ? (
              filteredChapters.map((chapter) => (
                <AccordionItem value={chapter.id} id={chapter.id} key={chapter.id}>
                  <AccordionTrigger className="text-base hover:no-underline">
                     <div className="flex justify-between items-center w-full">
                        <span>{chapter.title}</span>
                        {chapter.estimatedTime && <Badge variant="secondary" className="mr-4 font-normal"><Clock className="w-3 h-3 mr-1.5" />{chapter.estimatedTime}</Badge>}
                    </div>
                  </AccordionTrigger>
                   <AccordionContent className="space-y-4 text-foreground/90 prose prose-p:leading-relaxed">
                    <ChapterGoals goals={chapter.goals} />
                    {chapter.content}
                    {chapter.highlights && <ChapterHighlights highlights={chapter.highlights} />}
                  </AccordionContent>
                </AccordionItem>
              ))
            ) : (
              <div className="p-4 text-center text-muted-foreground">
                未找到与“{searchQuery}”匹配的结果。
              </div>
            )}
            {accordionType === 'single' ? (
              </Accordion>
            ) : (
              </Accordion>
            )}
        </CardContent>
      </Card>
    </div>
  );
}
