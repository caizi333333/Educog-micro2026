    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "babel-jest": "^30.0.5",
    "eslint-config-next": "^15.4.3",
    "genkit-cli": "^1.13.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "node-mocks-http": "^1.17.2",
    "postcss": "^8",
    "prisma": "^5.7.0",
    "string-replace-loader": "^3.2.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.0",
    "typescript": "^5",
    "zustand": "^5.0.6"
  }
