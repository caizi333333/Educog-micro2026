{
  "name": "xinzhi-yucai",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:clean": "bash -c 'lsof -ti :3000 | xargs kill -9 2>/dev/null || true && rm -rf .next && next dev -H 0.0.0.0 -p 3000'",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "check:fix": "npm run typecheck && npm run lint:fix",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "db:init": "tsx scripts/init-database.ts",
    "db:migrate": "./scripts/generate-migration.sh",
    "vercel-build": "prisma generate && prisma db push && next build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:unit": "jest src/__tests__/lib src/__tests__/hooks",
    "test:integration": "jest src/__tests__/integration",
    "test:api": "jest src/__tests__/api",
    "test:components": "jest src/__tests__/components",
    "test:performance": "node scripts/performance-test.js",
    "test:debug": "jest --detectOpenHandles --forceExit",
    "test:validate": "node scripts/validate-test-architecture.js",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@genkit-ai/googleai": "^1.13.0",
    "@genkit-ai/next": "^1.13.0",
    "@hookform/resolvers": "^4.1.3",
    "@prisma/client": "^5.7.0",
    "@radix-ui/react-accordion": "^1.2.3",
