generator client {
  provider = "prisma-client-js"
  // 兼容本地开发（native）与 CI/部署环境（Linux）
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                  @id @default(cuid())
  email              String                  @unique
  username           String                  @unique
  password           String
  name               String?
  avatar             String?
  role               String                  @default("STUDENT")
  status             String                  @default("ACTIVE")
  studentId          String?                 @unique
  class              String?
  grade              String?
  major              String?
  teacherId          String?                 @unique
  department         String?
  title              String?
  totalPoints        Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  lastLoginAt        DateTime?
  certificates       Certificate[]
  learningPaths      LearningPath[]
  learningProgress   LearningProgress[]
  quizAttempts       QuizAttempt[]
  sessions           Session[]
  achievements       UserAchievement[]
  activities         UserActivity[]
  experiments        UserExperiment[]
  pointsTransactions UserPointsTransaction[]
  userProgress       UserProgress?

  @@index([email])
  @@index([username])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model UserExperiment {
  id           String    @id @default(cuid())
  userId       String
  experimentId String
  status       String    @default("NOT_STARTED")
  score        Int?
  startedAt    DateTime?
  completedAt  DateTime?
  timeSpent    Int?
  attempts     Int       @default(0)
  lastCode     String?
  results      String?
  feedback     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experimentId])
  @@index([userId])
  @@index([experimentId])
  @@index([status])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  quizId         String
  score          Float
  totalQuestions Int
  correctAnswers Int
  timeSpent      Int
  answers        String
  startedAt      DateTime
  completedAt    DateTime
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([score])
  @@index([createdAt])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  name          String
  description   String
  icon          String?
  category      String
  unlockedAt    DateTime @default(now())
  progress      Int      @default(100)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([category])
}

model LearningPath {
  id            String             @id @default(cuid())
  userId        String
  name          String
  description   String?
  modules       String
  currentModule Int                @default(0)
  totalModules  Int
  status        String             @default("ACTIVE")
  startedAt     DateTime           @default(now())
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress      LearningProgress[]

  @@index([userId])
  @@index([status])
}

model LearningProgress {
  id           String        @id @default(cuid())
  userId       String
  pathId       String?
  moduleId     String
  chapterId    String
  status       String        @default("NOT_STARTED")
  progress     Int           @default(0)
  timeSpent    Int           @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  lastAccessAt DateTime      @default(now())
  notes        String?
  bookmarks    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  learningPath LearningPath? @relation(fields: [pathId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId, chapterId])
  @@index([userId])
  @@index([pathId])
  @@index([status])
}

model Certificate {
  id            String    @id @default(cuid())
  userId        String
  type          String
  name          String
  description   String?
  courseScore   Float?
  examScore     Float?
  totalScore    Float
  certificateNo String    @unique
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  metadata      String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([certificateNo])
}

model UserPointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  type        String
  description String
  metadata    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model UserProgress {
  id               String   @id @default(cuid())
  userId           String   @unique
  modulesCompleted Int      @default(0)
  totalTimeSpent   Int      @default(0)
  averageScore     Float?
  streakDays       Int      @default(0)
  lastActiveDate   DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastActiveDate])
}
